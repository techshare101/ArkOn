# 🤖 Agentic SEO Protocol

## Purpose
Optimize digital properties for AI agent discovery — not just Google crawlers. As LLMs, voice assistants, and autonomous agents become primary information retrievers, structured data and machine-readable content become the #1 ranking factor.

---

## 📋 JSON-LD Template Library

### Template 1: Local Business (MedSpa)
```json
{
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "@id": "https://[domain].com/#business",
  "name": "[Business Name]",
  "description": "[80-160 char description with primary keyword]",
  "url": "https://[domain].com",
  "telephone": "+1-[XXX]-[XXX]-[XXXX]",
  "email": "info@[domain].com",
  "image": "https://[domain].com/images/storefront.jpg",
  "logo": "https://[domain].com/images/logo.png",
  "priceRange": "$$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "[Street]",
    "addressLocality": "[City]",
    "addressRegion": "[State]",
    "postalCode": "[ZIP]",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "[LAT]",
    "longitude": "[LNG]"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "18:00"
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "[X.X]",
    "reviewCount": "[XXX]",
    "bestRating": "5"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Treatments & Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "MedicalProcedure",
          "name": "[Treatment Name]",
          "description": "[Treatment description]",
          "howPerformed": "[Brief procedure description]"
        }
      }
    ]
  },
  "sameAs": [
    "https://www.facebook.com/[page]",
    "https://www.instagram.com/[handle]",
    "https://www.yelp.com/biz/[slug]"
  ]
}
```

### Template 2: Service/Product Offer
```json
{
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://[domain].com/services/[slug]#service",
  "name": "[Service Name]",
  "description": "[Outcome-focused description, 100-200 chars]",
  "provider": {
    "@type": "Organization",
    "@id": "https://[domain].com/#business"
  },
  "serviceType": "[Category]",
  "areaServed": {
    "@type": "City",
    "name": "[City, State]"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "[Service] Packages",
    "itemListElement": [
      {
        "@type": "Offer",
        "name": "[Package Name]",
        "price": "[XXXX]",
        "priceCurrency": "USD",
        "description": "[What's included]",
        "validFrom": "[YYYY-MM-DD]"
      }
    ]
  },
  "review": [
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "[Name]" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5" },
      "reviewBody": "[Specific outcome-based testimonial]"
    }
  ]
}
```

### Template 3: FAQ (AI-Optimized)
```json
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "[Question that an AI agent would ask]",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "[Concise, factual answer — 1-3 sentences. Include specific numbers, timeframes, and outcomes.]"
      }
    }
  ]
}
```

### Template 4: HowTo (Procedure Steps)
```json
{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "[How to {achieve outcome}]",
  "description": "[Brief overview of the process]",
  "totalTime": "PT[X]M",
  "estimatedCost": {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": "[XXX]"
  },
  "step": [
    {
      "@type": "HowToStep",
      "name": "[Step Title]",
      "text": "[Step description with specific action]",
      "url": "https://[domain].com/[page]#step1"
    }
  ]
}
```

### Template 5: Breadcrumb Navigation
```json
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://[domain].com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "[Category]",
      "item": "https://[domain].com/[category]"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "[Current Page]",
      "item": "https://[domain].com/[category]/[page]"
    }
  ]
}
```

